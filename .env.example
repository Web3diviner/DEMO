# DEMO frontend environment. Copy to `.env.local` for local dev.

# Backend origin (used for CSP connect-src and the API client). Leave default while mocking.
NEXT_PUBLIC_API_ORIGIN=https://api.demo.example

# Media/CDN origin (CSP media-src/img-src). To see REAL playback in local dev with the mock,
# point this at the public test-stream host:
#   NEXT_PUBLIC_MEDIA_ORIGIN=https://test-streams.mux.dev
NEXT_PUBLIC_MEDIA_ORIGIN=https://cdn.demo.example

# Direct-to-storage resumable upload (tus) endpoint origin (CSP connect-src). With the mock this is
# the public tus demo server so uploads work end-to-end in dev.
NEXT_PUBLIC_UPLOAD_ORIGIN=https://tusd.tusdemo.net

# Use the in-memory mock backend (default true until the real API exists). Set to "false" to hit a
# real NEXT_PUBLIC_API_ORIGIN.
NEXT_PUBLIC_USE_MOCK=true

# Paystack publishable (public) key — safe for the client. NEVER put the secret key here.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
